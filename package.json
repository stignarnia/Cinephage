{
	"name": "cinephage",
	"private": true,
	"version": "0.0.0-development",
	"license": "GPL-3.0-or-later",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"dev:host": "vite dev --host",
		"build": "NODE_OPTIONS=--max-old-space-size=8192 VITE_SSR_BUILD=1 vite build",
		"start": "node server.js",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "NODE_OPTIONS=--max-old-space-size=8192 svelte-kit sync && NODE_OPTIONS=--max-old-space-size=8192 svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"lint:fix": "prettier --write . && eslint . --fix",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run",
		"test:coverage": "vitest run --coverage",
		"test:live": "LIVE_TESTS=true vitest run src/lib/server/subtitles/providers.live.test.ts",
		"deps:audit": "npx --yes knip --dependencies --include dependencies,devDependencies --no-progress --reporter compact",
		"migrate:remove-enabled": "tsx scripts/remove-monitoring-enabled.ts",
		"auth:reset-admin-password": "node scripts/reset-admin-password.js",
		"fix:tv-subtitles": "node scripts/fix-tv-subtitle-paths.js",
		"library:backfill-release-metadata": "npx tsx scripts/backfill-release-metadata.ts",
		"library:export-release-metadata-audit": "npx tsx scripts/export-release-metadata-audit.ts",
		"db:reset": "rm -f data/cinephage.db && echo 'Database deleted. Will be recreated on next startup.'",
		"db:info": "sqlite3 data/cinephage.db \"SELECT value FROM settings WHERE key='schema_version'\" 2>/dev/null || echo 'No database found'"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.5",
		"@eslint/js": "^9.39.2",
		"@inlang/paraglide-js": "^2.16.1",
		"@semantic-release/exec": "^7.1.0",
		"@semantic-release/github": "^12.0.6",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.58.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/vite": "^4.2.2",
		"@types/adm-zip": "^0.5.8",
		"@types/better-sqlite3": "^7.6.13",
		"@types/js-yaml": "^4.0.9",
		"@types/node": "^25.6.0",
		"@types/parse-torrent": "^5.8.8",
		"@vitest/browser": "^4.1.5",
		"@vitest/browser-playwright": "^4.1.5",
		"@vitest/coverage-v8": "^4.1.5",
		"daisyui": "^5.5.19",
		"drizzle-orm": "^0.45.2",
		"eslint": "^10.2.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.1",
		"globals": "^17.5.0",
		"lucide-svelte": "^1.0.1",
		"pino-pretty": "^13.1.3",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"semantic-release": "^25.0.3",
		"svelte": "^5.55.5",
		"svelte-check": "^4.4.5",
		"tailwindcss": "^4.1.14",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.59.1",
		"vite": "^8.0.10",
		"vitest": "^4.1.5"
	},
	"overrides": {
		"cookie": "^0.7.0",
		"devalue": "^5.7.1",
		"undici": "^7.25.0"
	},
	"optionalDependencies": {
		"@rollup/rollup-linux-arm64-gnu": "^4.60.2",
		"@rollup/rollup-linux-x64-gnu": "^4.60.2"
	},
	"dependencies": {
		"@better-auth/api-key": "^1.6.9",
		"better-auth": "^1.6.9",
		"adm-zip": "^0.5.16",
		"better-sqlite3": "^12.9.0",
		"camoufox-js": "^0.10.2",
		"cheerio": "^1.2.0",
		"chokidar": "^5.0.0",
		"date-format-parse": "^0.2.7",
		"dotenv": "^17.4.2",
		"fast-xml-parser": "^5.7.2",
		"fflate": "^0.8.2",
		"guessit-js": "^3.8.1",
		"iconv-lite": "^0.7.2",
		"js-yaml": "^4.1.1",
		"parse-torrent": "^11.0.19",
		"pino": "^10.3.1",
		"playwright-core": "^1.53.0",
		"zod": "^4.3.6"
	}
}
